node_modules/
dist/
*.log
.DS_Store
fixtures/**/.modonome/
!fixtures/portability/**/.modonome/
!fixtures/portability/**/.modonome/**
.modonome/runs/
**/.modonome/runs/
.modonome/queue/
**/.modonome/queue/
.env
.env.*
!fixtures/portability/**/.env
*.pem
*.key

# Loop orchestration state (internal build scaffolding, never merge to main)
.loop/

# Python build and cache artifacts
__pycache__/
*.pyc
*.egg-info/

# Claude / Anthropic Caches and Settings
.claude/
.claude_profile/
CLAUDE.md
runs/

# examples/demo-app/runs/ holds intentionally committed, verbatim evidence captures
# (dry-run output, ratchet rejections, Gauntlet scores) that back README and
# WALKTHROUGH.md claims: un-ignore that one path from the bare `runs/` rule above,
# which otherwise silently drops it from `git add -A` with no warning. Do not widen
# this to other `runs/` directories; agent-runtime scratch state stays ignored.
!examples/demo-app/runs/
!examples/demo-app/runs/**

# Tripwires ships a real .claude/settings.json under templates/: un-ignore that one
# tracked template (never the root-level, session-local .claude/ above).
!templates/.claude/
!templates/.claude/**

# Design-sync converter scratch, staged scripts, and generated upload bundle
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Frontend build output and local caches (dist/ already ignored above)
.vite/
*.tsbuildinfo

# Modonome snapshot portable pack (regenerate with: modonome snapshot --pack)
*.msnap

# Modonome snapshot local incremental cache (regenerated, never committed)
.modonome/cache/
