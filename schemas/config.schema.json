{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/config.schema.json",
  "title": "Modonome config",
  "description": "Spec of record: prompts/modonome.core.md Configuration. Defaults are safe.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "autonomy_enabled", "dry_run", "auto_merge", "state_dir"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "autonomy_enabled": { "type": "boolean" },
    "dry_run": { "type": "boolean" },
    "auto_merge": { "type": "boolean" },
    "max_attempts_per_item": { "type": "integer", "minimum": 1, "maximum": 10 },
    "max_open_prs": { "type": "integer", "minimum": 0, "maximum": 50 },
    "max_diff_lines": { "type": "integer", "minimum": 1 },
    "lease_minutes": { "type": "integer", "minimum": 1 },
    "max_merges_per_day": { "type": "integer", "minimum": 0 },
    "remote_model_budget_usd_per_day": { "type": "number", "minimum": 0 },
    "local_model_only_by_default": { "type": "boolean" },
    "require_branch_protection": { "type": "boolean" },
    "require_codeowner_review": { "type": "boolean" },
    "require_distinct_maker_checker": { "type": "boolean" },
    "require_distinct_maker_checker_model": { "type": "boolean" },
    "trusted_author_allowlist": { "type": "array", "items": { "type": "string" } },
    "protected_paths_extra": { "type": "array", "items": { "type": "string" } },
    "state_dir": { "type": "string", "minLength": 1 },
    "market_scan_enabled": { "type": "boolean" },
    "owner_approval_required_for_new_claims": { "type": "boolean" },
    "repo_network_enabled": { "type": "boolean" },
    "repo_network_dry_run": { "type": "boolean" },
    "share_raw_code_across_repos": { "type": "boolean" },
    "share_repo_identifiers_by_default": { "type": "boolean" },
    "remediation_apply_enabled": { "type": "boolean" },
    "snapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ci_mode": { "type": "string", "enum": ["warn", "fail", "disabled"] },
        "sign": { "type": "boolean" },
        "parser": { "type": "string" },
        "token_budget": { "type": "integer", "minimum": 0 },
        "strict_redact": { "type": "boolean" }
      }
    },
    "roles": {
      "type": "object",
      "description": "Role registry. maker and checker are the first-class separation-of-duties pair (a distinct model each is enforced by require_distinct_maker_checker_model). Any other key is a crew role added in config with no core-code change; it carries the same optional runner/model/provider/transport/trigger/execution-target fields.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "runner": { "type": "string", "enum": ["local", "container"] },
          "model": { "type": "string", "minLength": 1 },
          "models": {
            "type": "array",
            "description": "Prioritized model fallback list, highest priority first. When set, the loop tries these in order; `model` (if also set) is the authoritative primary. A budget-affordable local or free model can be listed as the fallback after a paid frontier choice.",
            "items": { "type": "string", "minLength": 1 }
          },
          "skills": {
            "type": "array",
            "description": "Declarative capability tags for this agent (for example adversarial-review, cite-sources). Read by the loop and prompts; grants no capability by itself.",
            "items": { "type": "string", "minLength": 1 }
          },
          "tools": {
            "type": "array",
            "description": "Declarative tool tags this agent is permitted (for example read-only-fs, web-search). Read by the loop; actual tool execution is gated separately.",
            "items": { "type": "string", "minLength": 1 }
          },
          "provider": { "type": "string", "minLength": 1 },
          "transport": { "type": "string", "minLength": 1 },
          "schedule": {
            "type": "object",
            "additionalProperties": false,
            "description": "Declarative cadence for a scheduled crew role. cron is a standard 5-field expression; timezone is an optional IANA name. Read by scripts/agent/triggers.mjs to emit .github/workflows/modonome-schedule.yml; it does not arm anything by itself.",
            "properties": {
              "cron": { "type": "string", "minLength": 1 },
              "timezone": { "type": "string", "minLength": 1 }
            }
          },
          "trigger": {
            "type": ["string", "object"],
            "additionalProperties": false,
            "description": "How this role is fired. A bare string is shorthand for { type: <string> }. type schedule emits cron in the generated workflow; after-role chains this role after the roles named in `after` (ordered by scripts/lib/graph.mjs, fail-closed on a cycle or a dangling name); manual, webhook, and on-merge are inert at runtime and only select which generated trigger fires.",
            "properties": {
              "type": { "type": "string", "enum": ["schedule", "manual", "webhook", "on-merge", "after-role"] },
              "after": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "cron": { "type": "string", "minLength": 1 }
            }
          },
          "execution_target": { "type": "string", "minLength": 1 }
        }
      }
    },
    "runners": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "labels": { "type": "array", "items": { "type": "string" } },
            "cli_path": { "type": "string", "minLength": 1 },
            "environment": { "type": "string", "minLength": 1 },
            "reachable_providers": { "type": "array", "items": { "type": "string" } },
            "reachable_endpoints": { "type": "array", "items": { "type": "string" } }
          }
        },
        "container": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "labels": { "type": "array", "items": { "type": "string" } },
            "cli_path": { "type": "string", "minLength": 1 },
            "environment": { "type": "string", "minLength": 1 },
            "reachable_providers": { "type": "array", "items": { "type": "string" } },
            "reachable_endpoints": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "provider": { "type": "string", "minLength": 1 },
          "base_url": { "type": "string", "minLength": 1 },
          "exec_mode": { "type": "string", "enum": ["patch", "tool-loop"] }
        }
      }
    },
    "providers": {
      "type": "object",
      "description": "Optional provider registry override/extension. Merged over the built-in registry in scripts/agent/providers.mjs.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "transport": { "type": "string", "minLength": 1 },
          "costClass": { "type": "string", "enum": ["paid", "free", "local"] },
          "authEnv": { "type": "string", "minLength": 1 },
          "base_url": { "type": "string", "minLength": 1 },
          "defaultBaseUrl": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
